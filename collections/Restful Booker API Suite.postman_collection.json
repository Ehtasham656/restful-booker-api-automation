  "item": [
    {
      "name": "Auth Module",
      "item": [
        {
          "name": "Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"token\", jsonData.token);\r",
                  "\r",
                  "console.log(\"TOKEN SAVED:\", jsonData.token);\r",
                  "\r",
                  "pm.test(\"Token generated\", function () {\r",
                  "    pm.expect(jsonData.token).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"admin\",\r\n  \"password\": \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
