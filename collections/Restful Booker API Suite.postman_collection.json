        {
          "name": "Get Booking By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Firstname exists\", function () {\r",
                  "    pm.expect(res.firstname).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Lastname exists\", function () {\r",
                  "    pm.expect(res.lastname).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Schema validation basic check\", function () {\r",
                  "    pm.expect(res).to.include.all.keys(\r",
                  "        \"firstname\",\r",
                  "        \"lastname\",\r",
                  "        \"totalprice\",\r",
                  "        \"depositpaid\",\r",
                  "        \"bookingdates\"\r",
                  "    );\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
