                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstname\": \"Ali\",\r\n  \"lastname\": \"Khan\",\r\n  \"totalprice\": 1500,\r\n  \"depositpaid\": true,\r\n  \"bookingdates\": {\r\n    \"checkin\": \"2026-06-01\",\r\n    \"checkout\": \"2026-06-05\"\r\n  },\r\n  \"additionalneeds\": \"Breakfast\"\r\n}",
