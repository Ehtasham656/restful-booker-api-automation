                  "let res = pm.response.json();\r",
                  "pm.environment.set(\"booking_id\", res.bookingid);\r",
                  "\r",
                  "pm.test(\"Booking created successfully\", function () {\r",
                  "    pm.expect(res.bookingid).to.exist;\r",
